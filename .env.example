# Navykus Production Environment Variables
# Copy to .env and fill in all values

# REQUIRED - Application
NODE_ENV=production
API_PORT=4000
SERVER_URL=https://navykus.org
CORS_ORIGIN=https://navykus.org

# REQUIRED - Payload CMS
PAYLOAD_SECRET=generate-with-openssl-rand-base64-32
PAYLOAD_PUBLIC_SERVER_URL=https://navykus.org/admin

# REQUIRED - Database (PostgreSQL for production)
# SQLite (file:./payload.db) ONLY for development
DATABASE_URL=postgresql://user:pass@host:5432/navykus?sslmode=require

# REQUIRED - Email (SMTP)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=noreply@navykus.org
SMTP_PASS=your-smtp-password
SMTP_FROM=noreply@navykus.org
SMTP_FROM_NAME=Navykus

# Admin user (created on first run via seed)
ADMIN_EMAIL=admin@navykus.org
ADMIN_PASSWORD=secure-random-password

# Optional - AI Translation
GOOGLE_GENAI_API_KEY=your-google-ai-key