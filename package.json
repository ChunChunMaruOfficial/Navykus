{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:site\" \"npm run dev:api\" \"npm run dev:admin\"",
    "dev:site": "vite --port=3000 --host=0.0.0.0 --strictPort",
    "dev:api": "tsx server/index.ts",
    "dev:admin": "cross-env PAYLOAD_PUBLIC_SERVER_URL=http://localhost:3001 next dev admin --port 3001 --hostname 0.0.0.0",
    "dev:full": "npm run dev",
    "dev:stop": "node scripts/stop-dev-ports.js",
    "build": "vite build",
    "build:admin": "cross-env PAYLOAD_PUBLIC_SERVER_URL=http://localhost:3001 next build admin",
    "start:api": "cross-env NODE_ENV=production tsx server/index.ts",
    "start:admin": "cross-env PAYLOAD_PUBLIC_SERVER_URL=http://localhost:3001 next start admin --port 3001 --hostname 0.0.0.0",
    "generate:importmap": "cross-env PAYLOAD_CONFIG_PATH=admin/payload.config.ts payload generate:importmap",
    "payload": "cross-env PAYLOAD_CONFIG_PATH=src/payload.config.ts payload",
    "seed:payload": "tsx scripts/seed-payload.ts",
    "preview": "vite preview",
    "clean": "rm -rf dist server.js",
    "lint": "tsc --noEmit",
    "i18n:check": "tsx scripts/check-i18n.ts"
  },
  "dependencies": {
    "@google/genai": "^2.4.0",
    "@libsql/client": "^0.17.4",
    "@payloadcms/db-sqlite": "^3.86.0",
    "@payloadcms/next": "^3.86.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "graphql": "^16.14.2",
    "i18next": "^26.3.6",
    "i18next-browser-languagedetector": "^8.2.1",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "multer": "^2.2.0",
    "next": "15.4.11",
    "payload": "^3.86.0",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "react-i18next": "^17.0.9",
    "vite": "^6.2.3"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/multer": "^2.2.0",
    "@types/node": "^22.14.0",
    "@types/react": "19.2.17",
    "autoprefixer": "^10.4.21",
    "concurrently": "^10.0.3",
    "cross-env": "^10.1.0",
    "esbuild": "^0.25.0",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.3"
  }
}
