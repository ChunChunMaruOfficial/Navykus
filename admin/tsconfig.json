{
  "extends": "../tsconfig.json",
  "compilerOptions": {
    "baseUrl": "..",
    "esModuleInterop": true,
    "incremental": true,
    "jsx": "preserve",
    "plugins": [
      {
        "name": "next"
      }
    ],
    "resolveJsonModule": true,
    "strict": false
  },
  "include": [
    "next-env.d.ts",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    "**/*.mts",
    "**/*.ts",
    "**/*.tsx",
    "../src/payload/**/*.ts",
    "../src/payload.config.ts",
    "../src/types.ts"
  ],
  "exclude": [
    "../node_modules"
  ]
}
